# Gmail Buddy Environment Configuration
# Copy this file to .env and fill in your actual values

# Google OAuth2 Credentials
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Application Configuration
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8020

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_AUCONTRAIRE_GMAILBUDDY=DEBUG

# Token-reference encryption key (AESEncryptionUtil)
# Format: Base64-encoded 256-bit (32-byte) AES key.
# Generate with: openssl rand -base64 32
# When unset: app uses an ephemeral per-session key (WARN at startup; token-reference
# cache won't survive restarts). Fine for local dev; set this for any persistent
# deployment to keep the cache valid across restarts.
APP_SECURITY_TOKEN_ENCRYPTION_KEY=

# Optional: Database Configuration (for future use)
# DATABASE_URL=jdbc:postgresql://localhost:5432/gmailbuddy
# DATABASE_USERNAME=gmailbuddy
# DATABASE_PASSWORD=password

# Optional: Redis Configuration (for future caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
TEST_RECIPIENT=
